{
  "extension_config": {
    "name": "Wtyczka Sensor - Przewijaj Ręką",
    "version": "1.0.0",
    "author": "WtyczkaSensor Project",
    "description": "Przewijaj strony www za pomocą gestów rąk"
  },
  
  "hand_detection": {
    "min_hand_detection_confidence": 0.5,
    "min_hand_presence_confidence": 0.5,
    "min_tracking_confidence": 0.5,
    "num_hands": 2,
    "running_mode": "VIDEO"
  },
  
  "gesture_recognition": {
    "enabled": true,
    "gestures": {
      "SCROLL_UP": {
        "name": "Przewijanie w górę",
        "description": "Unierz tylko palec wskazujący",
        "landmarks": {
          "index": "up",
          "middle": "down",
          "ring": "down",
          "pinky": "down"
        }
      },
      "SCROLL_DOWN": {
        "name": "Przewijanie w dół",
        "description": "Unierz tylko mały palec",
        "landmarks": {
          "index": "down",
          "middle": "down",
          "ring": "down",
          "pinky": "up"
        }
      },
      "ROCK": {
        "name": "Kamień",
        "description": "Zamknięta pięść",
        "action": "none"
      },
      "PAPER": {
        "name": "Papier",
        "description": "Otwarta dłoń",
        "action": "none"
      },
      "SCISSORS": {
        "name": "Nożyce",
        "description": "Indeks + Środek uniesione",
        "action": "none"
      }
    }
  },
  
  "scroll_settings": {
    "scroll_pixels": 50,
    "gesture_threshold": 0.5,
    "gesture_throttle_ms": 500,
    "scroll_behavior": "smooth"
  },
  
  "ui_settings": {
    "show_fps": true,
    "show_detection_stats": true,
    "show_gesture_name": true,
    "theme": "dark",
    "popup_timeout_ms": 3000
  },
  
  "camera_settings": {
    "width": 640,
    "height": 480,
    "fps": 30,
    "flip_horizontal": false
  },
  
  "performance": {
    "enable_gpu": true,
    "model_complexity": 0,
    "smooth_landmarks": true
  },
  
  "logging": {
    "enabled": true,
    "level": "info",
    "console": true,
    "file": {
      "enabled": false,
      "path": "logs/wtyczka_sensor.log"
    }
  },
  
  "advanced": {
    "custom_scroll_profile": {
      "enabled": false,
      "profiles": {
        "gentle": { "pixels": 20, "delay": 600 },
        "normal": { "pixels": 50, "delay": 500 },
        "fast": { "pixels": 100, "delay": 300 }
      }
    },
    "gesture_chaining": {
      "enabled": false,
      "timeout_ms": 1000
    },
    "hand_tracking_smoothing": {
      "enabled": true,
      "factor": 0.7
    }
  }
}
